# =============================================
# OTV Card Maker - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# Canva API (for background removal feature)
# Get from: https://www.canva.com/developers/
CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here

# Database (optional - app uses in-memory storage by default)
# Uncomment and fill if you want persistent storage
# DATABASE_URL=postgresql://user:password@localhost:5432/otv_db
